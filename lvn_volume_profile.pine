//@version=6
// =============================================================================
// Unmitigated LVN Volume Profile
// -----------------------------------------------------------------------------
// Builds manual fixed-range Volume Profiles on two independent tracks and marks
// the UNMITIGATED Low Volume Nodes (LVNs) of each as boxes parked on the
// profile:
//
//   * WEEKLY track  - one profile for the LAST COMPLETED week (Sun open -> Fri
//                     close). Plots only that week's still-unmitigated LVNs.
//   * DAILY  track  - one profile per trading day. Highlights the PRIOR day's
//                     LVNs and carries forward any earlier-in-the-week daily
//                     LVNs that have not yet been mitigated.
//
// Session handling: NOTHING about RTH/ETH is hardcoded. We simply profile the
// chart's bars as they are. Day/week boundaries are detected from the chart's
// own session (`time("D")`) and the calendar (`dayofweek`). On CME futures the
// session opens at 18:00 ET (6pm EST), so the per-day profiles end up anchored
// to that 6pm open automatically.
//
// There is no built-in fixed-range VP exposed to indicators, so the profile is
// computed manually (see buildProfile()): split the price span into N equal
// rows and spread each bar's volume across the rows its high-low overlaps.
// =============================================================================
indicator("Unmitigated LVN Volume Profile", overlay = true,
     max_boxes_count = 500, max_lines_count = 500, max_polylines_count = 100,
     max_bars_back = 5000)

// =============================================================================
// INPUTS
// =============================================================================
gProfile = "Profile"
rowsPerProfile = input.int(100, "Rows per profile", minval = 5, maxval = 500,
     group = gProfile,
     tooltip = "Number of equal-height price buckets each profile is split into.")
lvnCutoff = input.float(0.125, "LVN cutoff (normalized width)", minval = 0.0,
     maxval = 1.0, step = 0.005, group = gProfile,
     tooltip = "A row is a Low Volume Node when its volume, normalized so the " +
     "fattest row = 1.0, is BELOW this value. Default 0.125 = bottom ~12.5%.")

gGeom = "Geometry"
boxWidthBars = input.int(20, "Profile/box width (bars)", minval = 2,
     group = gGeom,
     tooltip = "Horizontal extent of the profile, in bars, drawn to the LEFT " +
     "of the session-open anchor line. LVN boxes span this full width.")

gMit = "Mitigation"
candlesToMitigate = input.int(4, "Candles to mitigate", minval = 1, group = gMit,
     tooltip = "How many bars must overlap an LVN's price band before it is " +
     "considered mitigated.")
mitigationCumulative = input.bool(true, "Cumulative (off = consecutive)",
     group = gMit,
     tooltip = "Cumulative = count every overlapping bar, anytime. " +
     "Consecutive = the run resets whenever a bar fails to overlap.")
mitigatedStyleDelete = input.bool(true, "Mitigated style: delete (off = grey)",
     group = gMit,
     tooltip = "On  = delete the box when mitigated. Off = recolor it grey.")
greyColor = input.color(color.new(color.gray, 35), "Mitigated grey color",
     group = gMit)

gColor = "Colors"
weeklyColor = input.color(color.new(color.orange, 0), "Weekly LVN color",
     group = gColor)
// Pine has no color-array input, so the per-weekday palette is one input per day
// and assembled into an array indexed by `dayofweek` (Sunday = 1 ... Saturday = 7).
cSun = input.color(color.new(#7E57C2, 0), "Sunday LVN",    group = gColor)
cMon = input.color(color.new(#26A69A, 0), "Monday LVN",    group = gColor)
cTue = input.color(color.new(#42A5F5, 0), "Tuesday LVN",   group = gColor)
cWed = input.color(color.new(#FFCA28, 0), "Wednesday LVN", group = gColor)
cThu = input.color(color.new(#EF5350, 0), "Thursday LVN",  group = gColor)
cFri = input.color(color.new(#EC407A, 0), "Friday LVN",    group = gColor)
cSat = input.color(color.new(#8D6E63, 0), "Saturday LVN",  group = gColor)
weekdayPalette = array.from(cSun, cMon, cTue, cWed, cThu, cFri, cSat)

gHk = "Housekeeping"
maxLookback = input.int(20, "Max lookback (profiles to keep / track)",
     minval = 1, group = gHk,
     tooltip = "Keep at most this many daily profiles AND this many weekly " +
     "profiles. Oldest are pruned (boxes deleted) so the 500-object cap is " +
     "never reached.")
showHistogram = input.bool(true, "Draw full histogram", group = gHk)
showAnchorLine = input.bool(true, "Draw anchor line", group = gHk)

// =============================================================================
// TYPES
// =============================================================================
// One LVN zone = one contiguous run of low-volume rows in a profile.
type LvnZone
    float top          // upper price of the zone's band
    float bottom       // lower price of the zone's band
    int   count        // mitigation tally (bars overlapping the band)
    bool  mitigated    // true once count reached the threshold
    bool  isWeekly     // weekly track vs daily track
    int   createdBar   // bar_index when the zone formed; mitigation counts after
    color colr         // active color (weekday palette or weekly color)
    box   bx           // the drawn box (na once deleted)

// Per-profile visuals (histogram + anchor line), tracked so they can be pruned
// together with their LVN boxes.
type ProfileViz
    bool     isWeekly
    line     anchorLn
    polyline hist

// =============================================================================
// STATE (persists across bars)
// =============================================================================
var array<LvnZone>    dailyZones   = array.new<LvnZone>()
var array<LvnZone>    weeklyZones  = array.new<LvnZone>()
var array<ProfileViz> dailyViz     = array.new<ProfileViz>()
var array<ProfileViz> weeklyViz    = array.new<ProfileViz>()

// Session/week range tracking.
var int dayOpenBar  = bar_index   // bar_index of the current session's open
var int dayOpenDow  = dayofweek   // weekday of the current session's open (1..7)
var int weekOpenBar = bar_index   // bar_index of the current week's open

// =============================================================================
// PROFILE BUILDER  (manual fixed-range volume profile - two passes)
// -----------------------------------------------------------------------------
// Given a range of `n` bars ending on the PREVIOUS bar (offsets 1..n), build the
// per-row volume array. Mirrors volume_profile.py::profile_arrays.
//   Pass 1: find the range high/low -> equal-height rows.
//   Pass 2: spread each bar's volume EVENLY across every row its high-low spans
//           (the standard approximation when tick data is unavailable).
// Returns the row-volume array; rangeLow / rowHeight are returned via the tuple.
// =============================================================================
buildProfile(int n) =>
    rows = rowsPerProfile
    rowVols = array.new_float(rows, 0.0)
    float rangeLow  = na
    float rangeHigh = na
    // Cap the look-back at max_bars_back so historical references never error
    // on very large ranges (e.g. a whole week on a 1m chart).
    nClamped = math.min(n, 4999)
    // --- Pass 1: extremes across the whole range ---
    for i = 1 to nClamped
        h = high[i]
        l = low[i]
        rangeHigh := na(rangeHigh) ? h : math.max(rangeHigh, h)
        rangeLow  := na(rangeLow)  ? l : math.min(rangeLow,  l)
    rowHeight = (rangeHigh - rangeLow) / rows
    // --- Pass 2: distribute volume into rows ---
    if rowHeight > 0
        for i = 1 to nClamped
            v = volume[i]
            if v > 0
                // Row index of this bar's low and high, clamped into [0, rows-1].
                loIdx = math.floor((low[i]  - rangeLow) / rowHeight)
                hiIdx = math.floor((high[i] - rangeLow) / rowHeight)
                loIdx := math.max(0, math.min(loIdx, rows - 1))
                hiIdx := math.max(0, math.min(hiIdx, rows - 1))
                span = hiIdx - loIdx + 1
                share = v / span                 // even split across spanned rows
                for r = loIdx to hiIdx
                    array.set(rowVols, r, array.get(rowVols, r) + share)
    [rowVols, rangeLow, rowHeight]

// =============================================================================
// LVN EXTRACTION  (WIDTH cutoff, NOT prominence)
// -----------------------------------------------------------------------------
// Normalize every row to the fattest row (fattest = 1.0, empty = 0.0). Any row
// whose normalized width is < lvnCutoff is a low-volume row. Contiguous low rows
// are merged into one zone whose band = combined height of those rows. This is a
// simple WIDTH threshold (the bottom ~12.5% of volume), not a peak/valley
// prominence test.
// Returns parallel arrays of zone bottoms and tops.
// =============================================================================
extractLvns(array<float> rowVols, float rangeLow, float rowHeight) =>
    rows = array.size(rowVols)
    maxVol = array.max(rowVols)
    bottoms = array.new_float()
    tops    = array.new_float()
    if maxVol > 0 and rowHeight > 0
        int runStart = na
        for r = 0 to rows - 1
            norm = array.get(rowVols, r) / maxVol        // normalized width
            isLow = norm < lvnCutoff
            if isLow and na(runStart)
                runStart := r                            // open a new run
            if (not isLow or r == rows - 1) and not na(runStart)
                // Close the run. If the last row itself is low, include it.
                runEnd = (not isLow) ? r - 1 : r
                array.push(bottoms, rangeLow + runStart * rowHeight)
                array.push(tops,    rangeLow + (runEnd + 1) * rowHeight)
                runStart := na
    [bottoms, tops]

// =============================================================================
// HISTOGRAM  (one polyline per profile, drawn LEFT of the open anchor)
// -----------------------------------------------------------------------------
// The fattest row reaches the full profile width; thinner rows are shorter. The
// silhouette is traced row-by-row as a single polyline so 100 rows cost ONE
// drawing object instead of 100.
// =============================================================================
drawHistogram(array<float> rowVols, float rangeLow, float rowHeight,
     int anchorBar, color col) =>
    rows = array.size(rowVols)
    maxVol = array.max(rowVols)
    polyline pl = na
    if showHistogram and maxVol > 0 and rowHeight > 0
        pts = array.new<chart.point>()
        for r = 0 to rows - 1
            len = math.round(boxWidthBars * (array.get(rowVols, r) / maxVol))
            yMid = rangeLow + (r + 0.5) * rowHeight
            array.push(pts, chart.point.from_index(anchorBar - len, yMid))
        pl := polyline.new(pts, closed = false,
             line_color = color.new(col, 55), line_width = 1)
    pl

// =============================================================================
// PRUNING  (FIFO by count - keeps object totals deterministic and bounded)
// =============================================================================
pruneZones(array<LvnZone> zones, int keep) =>
    // We allow several zones per profile, so cap zones at keep * (rough zones
    // per profile). Kept conservative so both tracks stay under the 500-box cap.
    maxZones = keep * 8
    while array.size(zones) > maxZones
        z = array.shift(zones)
        if not na(z.bx)
            box.delete(z.bx)

pruneViz(array<ProfileViz> vizArr, int keep) =>
    while array.size(vizArr) > keep
        v = array.shift(vizArr)
        if not na(v.anchorLn)
            line.delete(v.anchorLn)
        if not na(v.hist)
            polyline.delete(v.hist)

// =============================================================================
// PROFILE CONSTRUCTION  (build a range's profile, draw it, register its zones)
// =============================================================================
makeProfile(int n, int anchorBar, bool isWeekly, color col) =>
    if n >= 1
        [rowVols, rangeLow, rowHeight] = buildProfile(n)
        if not na(rangeLow) and rowHeight > 0
            // --- histogram + anchor line ---
            pl = drawHistogram(rowVols, rangeLow, rowHeight, anchorBar, col)
            line ln = na
            if showAnchorLine
                ln := line.new(anchorBar, rangeLow, anchorBar,
                     rangeLow + rowHeight * rowsPerProfile,
                     color = color.new(col, 40), width = 1)
            viz = ProfileViz.new(isWeekly, ln, pl)
            if isWeekly
                array.push(weeklyViz, viz)
                pruneViz(weeklyViz, maxLookback)
            else
                array.push(dailyViz, viz)
                pruneViz(dailyViz, maxLookback)
            // --- LVN zones -> boxes ---
            // (`for 0 to size-1` simply does not run when size == 0.)
            [bottoms, tops] = extractLvns(rowVols, rangeLow, rowHeight)
            for i = 0 to array.size(bottoms) - 1
                zb = array.get(bottoms, i)
                zt = array.get(tops, i)
                // Box: right edge ON the open anchor, extends LEFT boxWidthBars.
                bx = box.new(anchorBar - boxWidthBars, zt, anchorBar, zb,
                     border_color = col, border_width = 1,
                     bgcolor = color.new(col, 80))
                z = LvnZone.new(zt, zb, 0, false, isWeekly, bar_index, col, bx)
                if isWeekly
                    array.push(weeklyZones, z)
                else
                    array.push(dailyZones, z)
            if isWeekly
                pruneZones(weeklyZones, maxLookback)
            else
                pruneZones(dailyZones, maxLookback)

// =============================================================================
// MITIGATION  (logic-only, every bar)
// -----------------------------------------------------------------------------
// For every active zone whose band the CURRENT bar's high-low overlaps, advance
// its tally. Cumulative counts every overlap ever; consecutive resets the run on
// any non-overlapping bar. On reaching the threshold the zone is mitigated and
// its box is deleted (or greyed). The box never moves - its existence/color is
// the only mitigation signal.
// =============================================================================
mitigate(array<LvnZone> zones) =>
    if array.size(zones) > 0
        for i = 0 to array.size(zones) - 1
            z = array.get(zones, i)
            if not z.mitigated and bar_index > z.createdBar
                overlap = high >= z.bottom and low <= z.top
                if mitigationCumulative
                    if overlap
                        z.count := z.count + 1
                else
                    z.count := overlap ? z.count + 1 : 0
                if z.count >= candlesToMitigate
                    z.mitigated := true
                    // Two independent `if`s (no else) so the block has no
                    // mismatched-branch return type (CE10235).
                    if mitigatedStyleDelete and not na(z.bx)
                        box.delete(z.bx)
                        z.bx := na
                    if (not mitigatedStyleDelete) and not na(z.bx)
                        box.set_border_color(z.bx, greyColor)
                        box.set_bgcolor(z.bx, color.new(greyColor, 80))

// =============================================================================
// MAIN  (boundary detection + orchestration)
// =============================================================================
// New session = the chart's daily session rolled over (6pm ET on CME futures).
newSession = ta.change(time("D")) != 0 and not na(time("D")[1])
// New week = the first session of the week opens on Sunday.
newWeek = newSession and dayofweek == dayofweek.sunday

if newSession and barstate.isconfirmed
    if newWeek
        // The just-closed WEEK spans [weekOpenBar .. bar_index-1]; anchor at its
        // (Sunday) open. The week's final day is captured by this weekly profile
        // rather than a separate daily one.
        nWeek = bar_index - weekOpenBar
        makeProfile(nWeek, weekOpenBar, true, weeklyColor)
        // Start the new week fresh: carry forward ONLY current-week daily LVNs,
        // so clear whatever daily zones remain from the week that just ended.
        if array.size(dailyZones) > 0
            for i = 0 to array.size(dailyZones) - 1
                z = array.get(dailyZones, i)
                if not na(z.bx)
                    box.delete(z.bx)
            array.clear(dailyZones)
        weekOpenBar := bar_index
    else
        // The just-closed DAY spans [dayOpenBar .. bar_index-1]; anchor at its
        // open. Color by the weekday captured when that session opened.
        nDay = bar_index - dayOpenBar
        color dayCol = array.get(weekdayPalette, dayOpenDow - 1)
        makeProfile(nDay, dayOpenBar, false, dayCol)
    // Roll the day window forward to this new session's open.
    dayOpenBar := bar_index
    dayOpenDow := dayofweek

// Run mitigation on confirmed bars for both tracks.
if barstate.isconfirmed
    mitigate(dailyZones)
    mitigate(weeklyZones)
